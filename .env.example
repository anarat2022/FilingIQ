# Which provider to use: "ollama" (fully local, no key, no limits),
# "gemini" (free tier, no credit card, but rate-limited), or "openai" (paid)
LLM_PROVIDER=ollama

# Only needed if LLM_PROVIDER=gemini -- get a free key at
# https://aistudio.google.com/app/apikey (no credit card required)
GEMINI_API_KEY=your_gemini_api_key_here

# Only needed if LLM_PROVIDER=openai -- get one at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Only used if LLM_PROVIDER=ollama and Ollama is running on a non-default
# host/port. Leave commented out to use the default (http://localhost:11434).
# OLLAMA_HOST=http://localhost:11434
